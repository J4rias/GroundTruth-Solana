# ══════════════════════════════════════════════════════════════════════════════
# GroundTruth — Environment Variables
# Copy this file to .env and fill in the values.
# NEVER commit .env — it contains secrets.
# ══════════════════════════════════════════════════════════════════════════════

# ── Backend (apps/backend) ────────────────────────────────────────────────────

# Supabase PostgreSQL connection string
# Settings → Database → Connection string → URI
DATABASE_URL="postgresql://postgres:[PASSWORD]@db.[PROJECT_REF].supabase.co:5432/postgres"

# Redis (docker-compose local)
REDIS_URL="redis://:redis_secret@localhost:6379"

# API server
PORT=3001
CORS_ORIGIN="http://localhost:5173"
NODE_ENV="development"

# Solana
SOLANA_RPC_URL="https://api.devnet.solana.com"
SOLANA_KEYPAIR_PATH="./groundtruth-devnet.json"  # path to server keypair (NEVER commit!)
GROUNDTRUTH_PROGRAM_ID=""                         # fill after `anchor deploy`

# Supabase server-side (Settings → API → service_role key — NEVER expose to frontend)
SUPABASE_URL="https://[PROJECT_REF].supabase.co"
SUPABASE_SERVICE_ROLE_KEY=""                      # secret key — backend only

# ── Frontend (apps/frontend) — public variables, safe to expose ───────────────

VITE_API_URL="http://localhost:3001"
VITE_SOLANA_EXPLORER="https://explorer.solana.com"
VITE_SOLANA_CLUSTER="devnet"

# Supabase public (Settings → API → anon public key)
VITE_SUPABASE_URL="https://[PROJECT_REF].supabase.co"
VITE_SUPABASE_ANON_KEY=""                         # public key — safe in browser

# ── Simulator (simulator/) ────────────────────────────────────────────────────

SIMULATOR_API_URL="http://localhost:3001"
SIMULATOR_MODE="demo"               # demo (8s) | standard (5min) | low-power (15min)
SIMULATOR_INTERVAL_MS=8000          # 8000ms=demo · 300000=production · 900000=low-power
SIMULATOR_NODE_ID="GT-NODE-001"
SIMULATOR_FARM_PUBKEY=""            # pubkey of FarmAccount after initialize_farm
SIMULATOR_READINGS_COUNT=0          # 0 = infinite loop
